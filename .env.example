# D1 over HTTP (Node / Vercel): set account + token + database id. set: CLOUDFLARE_CONNECTION_TYPE=http
# OpenNext / Workers: use wrangler.jsonc D1 binding; set CLOUDFLARE_CONNECTION_TYPE=binding if REST vars are also set.
# CLOUDFLARE_CONNECTION_TYPE=binding|http
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=   # If set, Wrangler uses the token only — comment out to use `wrangler login` (OAuth). Or: USE_WRANGLER_OAUTH=1 ./scripts/deploy-cloudflare.sh
# CLOUDFLARE_D1_DATABASE_ID=
# Same D1 UUID for HTTP (above) and for Wrangler: pnpm run wrangler:sync writes wrangler.jsonc from wrangler.template.jsonc
# CLOUDFLARE_ENV= Wrangler environment name for deploy / preview (optional)
#
# OpenNext Cloudflare build sets CF_WORKER=true (see package.json) so native `sharp` is excluded from the Worker.
# Wrangler `vars` also sets CF_WORKER for runtime; leave unset for local Node / Vercel builds.

# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional: Drizzle push (default: on in development, off in production — run `payload migrate` in prod)
# PAYLOAD_DB_PUSH=true

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
